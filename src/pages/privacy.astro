---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Privacy Policy | AI for Biz Calculator">
  <Header />
  <main class="container" style="padding-top: 100px; padding-bottom: 60px;">
    <h1 class="text-3xl font-bold mb-6">Privacy Policy</h1>
    <div style="color: var(--color-text-secondary); line-height: 1.8; font-size: 0.95rem;">
      <p><strong>Last updated:</strong> April 2026</p>

      <h2 class="text-xl font-bold mt-8 mb-3" style="color: var(--color-text-primary);">What We Collect</h2>
      <p>When you use the AI for Biz Calculator, we collect the answers you provide during the calculation. If you optionally submit your email address, we store that to send you a copy of your results.</p>

      <h2 class="text-xl font-bold mt-8 mb-3" style="color: var(--color-text-primary);">How We Use Your Data</h2>
      <ul style="padding-left: 20px;">
        <li>Generate your personalized AI business report</li>
        <li>Send you a copy of your results (only if you provide your email)</li>
        <li>Improve our recommendation engine</li>
      </ul>
      <p class="mt-3">We do not sell your data. We do not share your individual responses with third parties.</p>

      <h2 class="text-xl font-bold mt-8 mb-3" style="color: var(--color-text-primary);">Cookies</h2>
      <p>We use minimal analytics to understand how the tool is used. No advertising cookies or trackers.</p>

      <h2 class="text-xl font-bold mt-8 mb-3" style="color: var(--color-text-primary);">Contact</h2>
      <p>Questions? Email <a href="mailto:patrick@epiphanydynamics.ai" style="color: var(--color-brand-primary);">patrick@epiphanydynamics.ai</a></p>
    </div>
  </main>
  <Footer />
</Base>
