---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Base title="AI for Biz Calculator | Free AI Automation Assessment for Your Business">
  <Header />

  <main style="padding-top: 72px;">
    <!-- Hero -->
    <section class="container flex flex-col items-center text-center py-20 md:py-28">
      <!-- Badge -->
      <div
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-medium mb-8"
        style="background: rgba(59, 130, 246, 0.08); border: 1px solid rgba(59, 130, 246, 0.2);"
      >
        <span class="w-2 h-2 rounded-full inline-block animate-pulse-glow" style="background: var(--color-brand-primary);"></span>
        <span style="color: var(--color-text-secondary);">Free &middot; No signup required &middot; 3 minutes</span>
      </div>

      <!-- Headline -->
      <h1
        class="text-4xl md:text-6xl font-extrabold mb-6 leading-tight"
        style="letter-spacing: -0.03em; text-wrap: balance;"
      >
        Find Out Exactly Where
        <span style="background: linear-gradient(135deg, var(--color-brand-primary), var(--color-brand-accent)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
          AI Can Save You Money
        </span>
      </h1>

      <!-- Subhead -->
      <p
        class="text-lg md:text-xl max-w-2xl mb-10"
        style="color: var(--color-text-secondary); line-height: 1.7; text-wrap: pretty;"
      >
        Answer a few questions about your business and get a detailed, personalized
        report showing the exact automations and AI systems that will have the
        biggest impact on your bottom line.
      </p>

      <!-- CTA -->
      <a href="/calculator" class="btn-primary text-lg px-10 py-4">
        Start Your Free Assessment
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/>
          <path d="M12 5l7 7-7 7"/>
        </svg>
      </a>

      <!-- Trust line -->
      <p class="mt-5 text-sm" style="color: var(--color-text-muted);">
        No email required to start &middot; Instant personalized report
      </p>
    </section>

    <!-- What You Get -->
    <section style="background: var(--color-bg-surface); border-top: 1px solid var(--color-border-default); border-bottom: 1px solid var(--color-border-default);">
      <div class="container-wide py-20">
        <h2 class="text-2xl md:text-3xl font-bold text-center mb-4">
          What You'll Get
        </h2>
        <p class="text-center mb-12 max-w-lg mx-auto" style="color: var(--color-text-secondary);">
          A real business report, not a generic quiz result. Specific to your industry, your size, and your pain points.
        </p>

        <div class="grid md:grid-cols-3 gap-6">
          <!-- Card 1 -->
          <div class="card flex flex-col items-center text-center">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-4" style="background: linear-gradient(135deg, rgba(59,130,246,0.15), rgba(59,130,246,0.05)); border: 1px solid rgba(59,130,246,0.2);">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
              </svg>
            </div>
            <h3 class="text-lg font-bold mb-2">AI Readiness Score</h3>
            <p class="text-sm" style="color: var(--color-text-secondary);">
              See exactly where your business stands on AI adoption compared to others in your industry.
            </p>
          </div>

          <!-- Card 2 -->
          <div class="card flex flex-col items-center text-center">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-4" style="background: linear-gradient(135deg, rgba(16,185,129,0.15), rgba(16,185,129,0.05)); border: 1px solid rgba(16,185,129,0.2);">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M9 12l2 2 4-4"/>
              </svg>
            </div>
            <h3 class="text-lg font-bold mb-2">Automation Roadmap</h3>
            <p class="text-sm" style="color: var(--color-text-secondary);">
              Get a prioritized list of specific automations ranked by ROI, with estimated time and cost savings.
            </p>
          </div>

          <!-- Card 3 -->
          <div class="card flex flex-col items-center text-center">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-4" style="background: linear-gradient(135deg, rgba(245,158,11,0.15), rgba(245,158,11,0.05)); border: 1px solid rgba(245,158,11,0.2);">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-warm)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 6v6l4 2"/>
              </svg>
            </div>
            <h3 class="text-lg font-bold mb-2">Implementation Timeline</h3>
            <p class="text-sm" style="color: var(--color-text-secondary);">
              A clear "start here, then this" roadmap tailored to your budget and technical comfort level.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="container-wide py-20">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-12">
        How It Works
      </h2>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="flex flex-col items-center text-center">
          <div
            class="w-12 h-12 rounded-full flex items-center justify-center text-xl font-bold mb-4"
            style="background: rgba(59, 130, 246, 0.1); color: var(--color-brand-primary); border: 2px solid rgba(59, 130, 246, 0.3);"
          >
            1
          </div>
          <h3 class="text-lg font-bold mb-2">Answer Questions</h3>
          <p class="text-sm" style="color: var(--color-text-secondary);">
            Tell us about your business, team size, current tools, and biggest pain points. Takes about 3 minutes.
          </p>
        </div>

        <div class="flex flex-col items-center text-center">
          <div
            class="w-12 h-12 rounded-full flex items-center justify-center text-xl font-bold mb-4"
            style="background: rgba(16, 185, 129, 0.1); color: var(--color-brand-accent); border: 2px solid rgba(16, 185, 129, 0.3);"
          >
            2
          </div>
          <h3 class="text-lg font-bold mb-2">We Analyze</h3>
          <p class="text-sm" style="color: var(--color-text-secondary);">
            Our engine cross-references your answers against 30+ proven automations and AI frameworks for your industry.
          </p>
        </div>

        <div class="flex flex-col items-center text-center">
          <div
            class="w-12 h-12 rounded-full flex items-center justify-center text-xl font-bold mb-4"
            style="background: rgba(245, 158, 11, 0.1); color: var(--color-brand-warm); border: 2px solid rgba(245, 158, 11, 0.3);"
          >
            3
          </div>
          <h3 class="text-lg font-bold mb-2">Get Your Report</h3>
          <p class="text-sm" style="color: var(--color-text-secondary);">
            Receive a detailed business report with specific recommendations, ROI estimates, and a prioritized action plan.
          </p>
        </div>
      </div>

      <div class="flex justify-center mt-12">
        <a href="/calculator" class="btn-primary">
          Start Now &mdash; It's Free
        </a>
      </div>
    </section>

    <!-- Industries -->
    <section style="background: var(--color-bg-surface); border-top: 1px solid var(--color-border-default); border-bottom: 1px solid var(--color-border-default);">
      <div class="container-wide py-20">
        <h2 class="text-2xl md:text-3xl font-bold text-center mb-4">
          Works for Every Industry
        </h2>
        <p class="text-center mb-10 max-w-lg mx-auto" style="color: var(--color-text-secondary);">
          Our recommendations are tailored to how your specific type of business actually operates.
        </p>

        <div class="flex flex-wrap justify-center gap-3 max-w-3xl mx-auto">
          {[
            'Med Spa', 'Dental', 'Chiropractic', 'Veterinary', 'Salon & Barbershop',
            'Fitness & Gym', 'Restaurant', 'Home Services', 'Real Estate',
            'Legal', 'Accounting', 'Insurance', 'Auto Repair', 'Cleaning Service',
            'Property Management', 'E-Commerce', 'Photography', 'Event Planning',
            'Daycare', 'Consulting', 'And More...'
          ].map(industry => (
            <span
              class="px-4 py-2 rounded-full text-sm"
              style="background: var(--color-bg-elevated); border: 1px solid var(--color-border-default); color: var(--color-text-secondary);"
            >
              {industry}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="container py-20 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">
        Ready to See What AI Can Do for Your Business?
      </h2>
      <p class="mb-8 max-w-lg mx-auto" style="color: var(--color-text-secondary);">
        No signup. No sales pitch. Just a clear picture of where automation fits in your business.
      </p>
      <a href="/calculator" class="btn-primary text-lg px-10 py-4">
        Take the Assessment
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/>
          <path d="M12 5l7 7-7 7"/>
        </svg>
      </a>
    </section>
  </main>

  <Footer />
</Base>
