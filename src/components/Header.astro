<header class="fixed top-0 left-0 right-0 z-50" style="background: rgba(10, 15, 28, 0.8); backdrop-filter: blur(12px); border-bottom: 1px solid var(--color-border-default);">
  <div class="container-wide flex items-center justify-between py-4">
    <a href="/" class="flex items-center gap-2.5 no-underline">
      <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, var(--color-brand-primary), var(--color-brand-accent));">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2L2 7l10 5 10-5-10-5z"/>
          <path d="M2 17l10 5 10-5"/>
          <path d="M2 12l10 5 10-5"/>
        </svg>
      </div>
      <span class="text-lg font-bold" style="color: var(--color-text-primary); letter-spacing: -0.02em;">
        AI for Biz
      </span>
    </a>
    <a
      href="https://epiphanydynamics.ai/book"
      target="_blank"
      rel="noopener noreferrer"
      class="btn-secondary text-sm py-2 px-5"
